# Copy to .env and fill in the values. .env is gitignored — never commit secrets.

# IOTEK app server base URL (login + device list, etc.)
IOTEK_BASE_URL=https://11-app-mop.iotek.ai

# Test account for local development / smoke test
ZMODO_TEST_EMAIL=
ZMODO_TEST_PASSWORD=

# Web preview only: URL of the local CORS proxy (proxy/server.mjs), e.g. http://localhost:8787/
# Leave blank for native builds (they call the API directly, no CORS).
EXPO_PUBLIC_API_PROXY=
